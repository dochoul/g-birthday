{
  "name": "gabia-birthday",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "build:server-bundle": "esbuild server/src/index.ts --bundle --platform=node --outfile=server/dist/bundle.js --external:xlsx",
    "build:electron": "npm run build && npm run build:server-bundle",
    "electron:dev": "npm run build:electron && electron .",
    "dist:mac": "npm run build:electron && electron-builder --mac",
    "dist:win": "npm run build:electron && electron-builder --win",
    "dist:all": "npm run build:electron && electron-builder --mac --win"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^35.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.gabia.birthday",
    "productName": "Gabia Birthday",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/main.js",
      "electron/ko.lproj",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server/dist",
        "to": "server/dist"
      },
      {
        "from": "server/public",
        "to": "server/public"
      },
      {
        "from": "server/data/sample_birthday.xlsx",
        "to": "server/data/sample_birthday.xlsx"
      },
      {
        "from": "server/.env",
        "to": "server/.env",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "server/.env.example",
        "to": "server/.env.example",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/xlsx",
        "to": "node_modules/xlsx"
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "electron/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ko",
        "en"
      ]
    }
  }
}
